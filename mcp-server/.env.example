# Скопируйте этот файл под именем .env и вставьте данные вашего приложения VK Ads.
# При первом обращении сервер сам получит токен и запишет его ниже.
# .env уже исключён из Git и остаётся только на вашем компьютере.

VK_ADS_PROFILE=default
VK_ADS_MODE=readonly
# При VK_ADS_LOG=1 в stderr выводится только обезличенная metadata HTTP-запросов.
VK_ADS_LOG=0
# Таймаут API-запросов: от 1000 до 120000 мс.
VK_ADS_TIMEOUT_MS=30000
# ID локального подключения: буквы, цифры, _ и -.
VK_ADS_CONNECTION_ID=default
# Необязательный путь к локальному audit write-операций: только ID, статусы и хеши.
# По умолчанию: .vk-ads-audit.json рядом с package.json.
VK_ADS_AUDIT_FILE=
# Одноразовый preview записи действует 10 минут по умолчанию; допустимо 1–60.
# VK_ADS_PREVIEW_TTL_MINUTES=60
# По умолчанию каждая запись требует точную фразу подтверждения из preview.
# Только владелец локального профиля может отключить это требование: preview, preflight,
# audit и reread сохраняются, но write_execute принимает один свежий preview без фразы.
# VK_ADS_REQUIRE_WRITE_CONFIRMATION=0
VK_ADS_CLIENT_ID=
VK_ADS_CLIENT_SECRET=

# Заполняются сервером автоматически. Не вставляйте сюда токен вручную.
# VK_ADS_REFRESH_TOKEN обязателен для продления access token без создания нового.
VK_ADS_TOKEN=
VK_ADS_REFRESH_TOKEN=
VK_ADS_TOKEN_EXPIRES_AT=

# Каталог обычных медиафайлов. Нужен только для загрузок.
VK_ADS_UPLOAD_DIR=
# Опасные категории записи включаются отдельно и по умолчанию выключены.
VK_ADS_ALLOW_PII_UPLOADS=0
VK_ADS_PII_UPLOAD_DIR=
VK_ADS_ALLOW_AGENCY_WRITES=0
VK_ADS_ALLOW_SHARING_KEY_REVOKE=0
VK_ADS_ALLOW_SKADNETWORK_WRITES=0
VK_ADS_TEST_IOS_APP_IDS=
VK_ADS_ALLOW_INAPP_EVENT_CATEGORY_WRITES=0
VK_ADS_TEST_MOBILE_APP_IDS=
VK_ADS_ALLOW_REMARKETING_COUNTER_WRITES=0
VK_ADS_TEST_COUNTER_IDS=
VK_ADS_ALLOW_PROFILE_WRITES=0
VK_ADS_ALLOW_ORD_WRITES=0
VK_ADS_ALLOW_FINANCIAL_WRITES=0
# Внешний ключ шаринга хранится только локально и не показывается в MCP или audit.
VK_ADS_EXTERNAL_SHARING_KEY=
