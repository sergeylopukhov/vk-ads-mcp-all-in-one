{
  "name": "vk-ads-mcp-all-in-one",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Локальный MCP-сервер для анализа и безопасной работы с VK Ads",
  "bin": {
    "vk-ads-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs && vitest run",
    "api:check": "npm run build && node scripts/check-api-contracts.mjs && node scripts/check-vk-ads-api-docs.mjs",
    "matrix:generate": "node scripts/generate-api-coverage-matrix.mjs",
    "matrix:check": "npm run build && node scripts/check-api-coverage-matrix.mjs",
    "repo:check": "node scripts/check-repository-boundaries.mjs",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
