# Это справочный список переменных. Node.js не читает .env автоматически:
# передайте значения через конфигурацию MCP-клиента или окружение процесса.

# Имя изолированного профиля и безопасный режим по умолчанию.
VK_ADS_PROFILE=default
VK_ADS_MODE=readonly

# Единственный способ авторизации: личный токен VK Ads.
# VK_ADS_TOKEN=

# Переносимое зашифрованное хранилище вместо macOS Keychain.
# Не сохраняйте пароль в этом файле или в Git.
# VK_ADS_SECRET_STORE=encrypted-file
# VK_ADS_SECRET_PASSPHRASE=use-a-unique-long-passphrase
# VK_ADS_SECRETS_FILE=/absolute/path/outside/repository/secrets.enc
